# Tracking Sync
# =====================================================================

#: admin/partials/settings-page.php
msgid "Tracking Sync"
msgstr "Sincronización del seguimiento"

#: admin/partials/settings-page.php
msgid "When a tracking number is added to a WooCommerce order, it will be automatically sent to Hou.la so buyers can track their shipment."
msgstr "Cuando se añade un número de seguimiento a un pedido de WooCommerce, se enviará automáticamente a Hou.la para que los compradores puedan seguir su envío."

#: admin/partials/settings-page.php
msgid "Auto-sync tracking"
msgstr "Sincronización automática del seguimiento"

#: admin/partials/settings-page.php
msgid "Automatically push tracking numbers to Hou.la when added in WooCommerce"
msgstr "Envía automáticamente los números de seguimiento a Hou.la cuando se añaden en WooCommerce"

#: admin/partials/settings-page.php
msgid "Supported plugins"
msgstr "Plugins compatibles"

#: admin/partials/settings-page.php
msgid "Advanced Shipment Tracking (AST)"
msgstr "Advanced Shipment Tracking (AST)"

#: admin/partials/settings-page.php
msgid "WooCommerce Shipment Tracking"
msgstr "WooCommerce Shipment Tracking"

#: admin/partials/settings-page.php
msgid "YITH WooCommerce Order Tracking"
msgstr "YITH WooCommerce Order Tracking"

#: admin/partials/settings-page.php
msgid "Or any plugin storing tracking in order meta"
msgstr "O cualquier plugin que guarde el seguimiento en los metadatos del pedido"

#: admin/partials/settings-page.php
msgid "Tracking links are generated automatically for major carriers (Colissimo, DPD, GLS, Chronopost, UPS, FedEx, DHL, etc.)."
msgstr "Los enlaces de seguimiento se generan automáticamente para los principales transportistas (Colissimo, DPD, GLS, Chronopost, UPS, FedEx, DHL, etc.)."

